{
  "name": "@pe/llm-unified-client",
  "version": "1.0.0",
  "description": "Unified TypeScript client for LLM providers (OpenAI, DeepSeek, Qwen, Azure, Cohere)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "openai",
    "deepseek",
    "qwen",
    "azure",
    "cohere",
    "embeddings",
    "chat"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:yhwhpe/llm-unified-client-ts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
